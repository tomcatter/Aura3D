<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://sunce.tech/aura3d"
             x:Class="Example.Pages.PointCloudPage">
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10" Spacing="10">
            <TextBlock Text="Point Count:" VerticalAlignment="Center"/>
            <TextBox x:Name="pointCountTextBox" Text="20000" Width="80"/>
            <Button Content="Regenerate" Click="RegenerateButton_Click"/>
            <TextBlock x:Name="infoText" Text="Points: -- | FPS: --" VerticalAlignment="Center"/>
        </StackPanel>

        <a:Aura3DView x:Name="aura3Dview"
                       SceneInitialized="Aura3DView_SceneInitialized"
                       SceneUpdated="Aura3DView_SceneUpdated"/>
    </DockPanel>
</UserControl>
