<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://github.com/CeSun/Aura3D"
             x:Class="Example.Pages.PointCloudPage">
    <DockPanel>
        <StackPanel Orientation="Vertical" DockPanel.Dock="Top" Margin="10" Spacing="4">
            <!-- Row 1: Shape + Size -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Shape:" VerticalAlignment="Center"/>
                <ComboBox x:Name="shapeComboBox" Width="80" SelectedIndex="0">
                    <ComboBoxItem>Box</ComboBoxItem>
                    <ComboBoxItem>Sphere</ComboBoxItem>
                    <ComboBoxItem>Disk</ComboBoxItem>
                </ComboBox>
                <TextBlock Text="X:" VerticalAlignment="Center"/>
                <TextBox x:Name="sizeXTextBox" Text="20" Width="50"/>
                <TextBlock Text="Y:" VerticalAlignment="Center"/>
                <TextBox x:Name="sizeYTextBox" Text="20" Width="50"/>
                <TextBlock Text="Z:" VerticalAlignment="Center"/>
                <TextBox x:Name="sizeZTextBox" Text="20" Width="50"/>
                <TextBlock Text="PtSize:" VerticalAlignment="Center"/>
                <TextBox x:Name="pointSizeTextBox" Text="5" Width="40"/>
                <TextBlock Text="Grid:" VerticalAlignment="Center"/>
                <TextBox x:Name="gridTextBox" Text="4" Width="30"/>
            </StackPanel>
            <!-- Row 2: Count + Buttons -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Count:" VerticalAlignment="Center"/>
                <TextBox x:Name="pointCountTextBox" Text="20000" Width="80"/>
                <Button Content="Regenerate" Click="RegenerateButton_Click"/>
                <TextBlock x:Name="infoText" Text="Points: -- | FPS: --" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <a:Aura3DView x:Name="aura3Dview"
                       SceneInitialized="Aura3DView_SceneInitialized"
                       SceneUpdated="Aura3DView_SceneUpdated"/>
    </DockPanel>
</UserControl>
