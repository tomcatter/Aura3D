<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:a="https://github.com/CeSun/Aura3D"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Example.ViewModels"
             x:DataType="vm:RenderingPerformanceViewModel"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="650"
             x:Class="Example.Pages.RenderingPerformancePage">

  <Design.DataContext>
    <vm:RenderingPerformanceViewModel />
  </Design.DataContext>

  <DockPanel>
    <!-- Right control panel -->
    <ScrollViewer DockPanel.Dock="Right" Width="300">
      <StackPanel Spacing="8" Margin="8">

        <!-- Technique Selection -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="6">
            <TextBlock FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="Rendering Technique" />
            <ComboBox x:Name="techniqueCombo" SelectedIndex="{Binding TechniqueIndex}">
              <ComboBoxItem>Individual Meshes</ComboBoxItem>
              <ComboBoxItem>GPU Instancing</ComboBoxItem>
              <ComboBoxItem>HISM (Hierarchical)</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="Same grid, different draw strategy"
                       FontStyle="Italic" FontSize="11"
                       Foreground="{DynamicResource SemiGrey10}" />
          </StackPanel>
        </Border>

        <!-- Shared Params -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="6">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="Grid Config" />
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock VerticalAlignment="Center" Text="Cubes:" Width="50" />
                <TextBox x:Name="cubeCountBox" Text="{Binding CubeCountText}" Width="70" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock VerticalAlignment="Center" Text="Spacing:" Width="50" />
                <TextBox x:Name="spacingBox" Text="{Binding SpacingText}" Width="55" />
              </StackPanel>
              <Button x:Name="buildButton" HorizontalAlignment="Stretch"
                      FontWeight="Bold">🔨 Build</Button>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Real-time FPS Display -->
        <Border Theme="{StaticResource CardBorder}" Padding="10"
                Background="#1E1E2E">
          <StackPanel Spacing="6">
            <!-- Big FPS number -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
              <TextBlock Text="{Binding CurrentFps}" FontSize="36" FontWeight="Bold"
                         Foreground="White" />
              <TextBlock Text="FPS" FontSize="14" Foreground="#888"
                         VerticalAlignment="Bottom" Margin="0,0,0,6" />
            </StackPanel>

            <!-- FPS bar -->
            <Border Background="#333" CornerRadius="3" Height="8" HorizontalAlignment="Stretch">
              <Border Background="{Binding FpsBarColor}" CornerRadius="3"
                      Width="{Binding FpsBarWidth}" Height="8"
                      HorizontalAlignment="Left" />
            </Border>

            <!-- Min / Max / Avg -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
              <StackPanel Spacing="0">
                <TextBlock Text="MIN" FontSize="10" Foreground="#888"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding MinFps}" FontSize="16" FontWeight="Bold"
                           Foreground="#FF6B6B" HorizontalAlignment="Center" />
              </StackPanel>
              <StackPanel Spacing="0">
                <TextBlock Text="AVG" FontSize="10" Foreground="#888"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding AvgFps}" FontSize="16" FontWeight="Bold"
                           Foreground="#FFD93D" HorizontalAlignment="Center" />
              </StackPanel>
              <StackPanel Spacing="0">
                <TextBlock Text="MAX" FontSize="10" Foreground="#888"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding MaxFps}" FontSize="16" FontWeight="Bold"
                           Foreground="#6BCB77" HorizontalAlignment="Center" />
              </StackPanel>
            </StackPanel>

            <!-- Detail -->
            <TextBlock Text="{Binding DetailText}" FontSize="11"
                       Foreground="#AAA" HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Individual Meshes Controls -->
        <Border Theme="{StaticResource CardBorder}" Padding="10"
                IsVisible="{Binding IsIndividualMode}">
          <StackPanel Spacing="4">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="🔴 Individual Meshes" />
            <TextBlock Text="Each cube = 1 Mesh node = 1 draw call"
                       FontSize="11" TextWrapping="Wrap" />
            <CheckBox x:Name="cullingCheck"
                      IsChecked="{Binding EnableFrustumCulling}">
              Enable Frustum Culling
            </CheckBox>
            <TextBlock Text="💡 Toggle culling to see FPS gain"
                       FontStyle="Italic" FontSize="11"
                       Foreground="{DynamicResource SemiGrey10}" />
          </StackPanel>
        </Border>

        <!-- GPU Instancing Controls -->
        <Border Theme="{StaticResource CardBorder}" Padding="10"
                IsVisible="{Binding IsInstancedMode}">
          <StackPanel Spacing="4">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="🟢 GPU Instancing" />
            <TextBlock Text="All N³ cubes = 1 InstancedMesh = 1 draw call"
                       FontSize="11" TextWrapping="Wrap" />
            <TextBlock Text="Per-instance: random color + rotation animation"
                       FontSize="11" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- HISM Controls -->
        <Border Theme="{StaticResource CardBorder}" Padding="10"
                IsVisible="{Binding IsHISMMode}">
          <StackPanel Spacing="6">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="🔵 HISM (Hierarchical Instanced)" />
            <TextBlock Text="InstancedMeshGroup: spatial partition tree"
                       FontSize="11" TextWrapping="Wrap" />

            <StackPanel Spacing="3">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock VerticalAlignment="Center" Text="Max/Group:" Width="70" FontSize="12" />
                <TextBox x:Name="hismMaxGroupBox" Text="{Binding HismMaxPerGroupText}" Width="50" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock VerticalAlignment="Center" Text="Max Depth:" Width="70" FontSize="12" />
                <TextBox x:Name="hismMaxDepthBox" Text="{Binding HismMaxDepthText}" Width="50" />
              </StackPanel>
            </StackPanel>

            <CheckBox x:Name="hismCullingCheck" IsChecked="True">
              Frustum Culling
            </CheckBox>

            <Separator />
            <TextBlock FontWeight="Bold" Text="Move Instance" FontSize="13" />
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock VerticalAlignment="Center" Text="Idx:" Width="28" />
              <TextBox x:Name="instIdxBox" Text="{Binding InstanceIdxText}" Width="55" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock VerticalAlignment="Center" Text="X:" Width="28" />
              <TextBox x:Name="posXBox" Text="{Binding PosXText}" Width="50" />
              <TextBlock VerticalAlignment="Center" Text="Y:" Width="12" />
              <TextBox x:Name="posYBox" Text="{Binding PosYText}" Width="50" />
              <TextBlock VerticalAlignment="Center" Text="Z:" Width="12" />
              <TextBox x:Name="posZBox" Text="{Binding PosZText}" Width="50" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button x:Name="updateInstButton">Update</Button>
              <Button x:Name="randomMoveButton">Random Move</Button>
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- 3D Viewport -->
    <a:Aura3DView x:Name="aura3Dview"
                  SceneInitialized="Aura3DView_SceneInitialized"
                  SceneUpdated="Aura3DView_SceneUpdated" />
  </DockPanel>
</UserControl>
