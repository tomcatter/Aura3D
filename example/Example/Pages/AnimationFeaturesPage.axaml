<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:a="https://github.com/CeSun/Aura3D"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Example.ViewModels"
             x:DataType="vm:AnimationFeaturesViewModel"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             x:Class="Example.Pages.AnimationFeaturesPage">

  <Design.DataContext>
    <vm:AnimationFeaturesViewModel />
  </Design.DataContext>

  <DockPanel>
    <!-- Right control panel -->
    <ScrollViewer DockPanel.Dock="Right" Width="320">
      <StackPanel Spacing="8" Margin="8">

        <!-- Demo Mode Selection -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="6">
            <TextBlock FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="Demo Mode" />
            <ComboBox x:Name="demoModeCombo" SelectedIndex="{Binding DemoModeIndex}">
              <ComboBoxItem>Basic Animation</ComboBoxItem>
              <ComboBoxItem>Animation Graph</ComboBoxItem>
              <ComboBoxItem>Blend Space</ComboBoxItem>
            </ComboBox>
          </StackPanel>
        </Border>

        <!-- Basic Animation Controls -->
        <Border Theme="{StaticResource CardBorder}" Padding="10"
                IsVisible="{Binding IsBasicMode}">
          <StackPanel Spacing="8">
            <TextBlock FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="Animation Selection" />

            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock VerticalAlignment="Center" Text="Clip:" />
              <ComboBox ItemsSource="{Binding Animations}"
                        SelectedValue="{Binding SelectedAnimation}"
                        x:Name="animationCombo" />
            </StackPanel>

            <!-- Loop Mode (Cycle Type) -->
            <TextBlock FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="Loop Mode (Cycle Type)" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <RadioButton GroupName="LoopMode" x:Name="loopRadio">🔁 Loop</RadioButton>
              <RadioButton GroupName="LoopMode" x:Name="onceRadio">▶️ Once</RadioButton>
              <RadioButton GroupName="LoopMode" x:Name="pingPongRadio">↔️ PingPong</RadioButton>
            </StackPanel>

            <!-- Speed -->
            <StackPanel Spacing="2">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock VerticalAlignment="Center" Text="Speed:" />
                <TextBlock VerticalAlignment="Center" Text="{Binding SpeedString}" />
                <TextBlock VerticalAlignment="Center" Text="×" />
              </StackPanel>
              <Slider Minimum="0.1" Maximum="3.0" Value="{Binding Speed}"
                      TickFrequency="0.1" x:Name="speedSlider"
                      HorizontalAlignment="Stretch" />
            </StackPanel>

            <!-- External Update & Reset -->
            <StackPanel Orientation="Horizontal" Spacing="12">
              <CheckBox x:Name="externalUpdateCheck"
                        IsChecked="{Binding IsExternalUpdate}">External Update</CheckBox>
              <Button x:Name="resetButton">🔄 Reset</Button>
            </StackPanel>

            <Border Background="{DynamicResource SemiGrey2}" Padding="6" CornerRadius="4">
              <TextBlock Text="{Binding PlaybackStatus}" FontStyle="Italic"
                         Foreground="{DynamicResource SemiGrey10}" />
            </Border>
          </StackPanel>
        </Border>

        <!-- Animation Graph Controls -->
        <Border Theme="{StaticResource CardBorder}" Padding="10"
                IsVisible="{Binding IsGraphMode}">
          <StackPanel Spacing="8">
            <TextBlock FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="Animation Graph" />
            <TextBlock Text="State Machine: Idle ⇄ Jog Forward" TextWrapping="Wrap" />

            <Border Background="{DynamicResource SemiGrey2}" Padding="6" CornerRadius="4">
              <StackPanel Spacing="2">
                <TextBlock Text="Conditions:" FontWeight="Bold" FontSize="12" />
                <TextBlock Text="  Speed &gt; 150  →  Jog Forward" FontSize="12" />
                <TextBlock Text="  Speed &lt; 150  →  Idle" FontSize="12" />
                <TextBlock Text="Blend: 0.5s (idle) / 0.3s (jog)" FontSize="12" />
              </StackPanel>
            </Border>

            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock VerticalAlignment="Center" Text="Speed:" />
                <TextBlock VerticalAlignment="Center" Text="{Binding GraphSpeed, StringFormat={}{0:F0}}" />
              </StackPanel>
              <Slider Minimum="0" Maximum="600" Value="{Binding GraphSpeed}"
                      x:Name="graphSpeedSlider" HorizontalAlignment="Stretch" />
            </StackPanel>

            <TextBlock Text="💡 Drag the slider to trigger state transitions"
                       FontStyle="Italic" FontSize="12"
                       Foreground="{DynamicResource SemiGrey10}" />
          </StackPanel>
        </Border>

        <!-- Blend Space Controls -->
        <Border Theme="{StaticResource CardBorder}" Padding="10"
                IsVisible="{Binding IsBlendSpaceMode}">
          <StackPanel Spacing="8">
            <TextBlock FontSize="15" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="Animation Blend Space (IDW)" />
            <TextBlock Text="Inverse Distance Weighting 2D Blend" TextWrapping="Wrap"
                       FontSize="12" />

            <Border Background="{DynamicResource SemiGrey2}" Padding="6" CornerRadius="4">
              <StackPanel Spacing="2">
                <TextBlock Text="Layout Map (7 points):" FontWeight="Bold" FontSize="12" />
                <TextBlock Text="  ( 0,  0)  =  Idle" FontFamily="Courier New" FontSize="12" />
                <TextBlock Text="  ( 0, +1)  =  Jog Forward" FontFamily="Courier New" FontSize="12" />
                <TextBlock Text="  ( 0, -1)  =  Jog Backward" FontFamily="Courier New" FontSize="12" />
                <TextBlock Text="  (-1,  0)  =  Jog Left" FontFamily="Courier New" FontSize="12" />
                <TextBlock Text="  (+1,  0)  =  Jog Right" FontFamily="Courier New" FontSize="12" />
                <TextBlock Text="  (-1, -1)  =  Walk Back-Left" FontFamily="Courier New" FontSize="12" />
                <TextBlock Text="  (+1, -1)  =  Walk Back-Right" FontFamily="Courier New" FontSize="12" />
              </StackPanel>
            </Border>

            <!-- X Axis Slider (full width, standalone row) -->
            <StackPanel Spacing="2">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock VerticalAlignment="Center" Text="X:" Width="16" />
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding BlendX, StringFormat={}{0:F2}}" MinWidth="36" />
                <TextBlock VerticalAlignment="Center" Text="Left -1  .  0  .  +1 Right"
                           FontSize="10" Foreground="{DynamicResource SemiGrey8}" />
              </StackPanel>
              <Slider Minimum="-1" Maximum="1" Value="{Binding BlendX}"
                      x:Name="blendXSlider" HorizontalAlignment="Stretch"
                      TickFrequency="0.25" IsSnapToTickEnabled="True" />
            </StackPanel>

            <!-- Y Axis Slider (full width, standalone row) -->
            <StackPanel Spacing="2">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock VerticalAlignment="Center" Text="Y:" Width="16" />
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding BlendY, StringFormat={}{0:F2}}" MinWidth="36" />
                <TextBlock VerticalAlignment="Center" Text="Back -1  .  0  .  +1 Fwd"
                           FontSize="10" Foreground="{DynamicResource SemiGrey8}" />
              </StackPanel>
              <Slider Minimum="-1" Maximum="1" Value="{Binding BlendY}"
                      x:Name="blendYSlider" HorizontalAlignment="Stretch"
                      TickFrequency="0.25" IsSnapToTickEnabled="True" />
            </StackPanel>

            <TextBlock Text="💡 Move sliders to blend between animations"
                       FontStyle="Italic" FontSize="12"
                       Foreground="{DynamicResource SemiGrey10}" />
          </StackPanel>
        </Border>

        <!-- Bone Attachment Offset -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="6">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="🔧 Torch Offset" />

            <!-- Position -->
            <TextBlock FontSize="12" FontWeight="Bold" Text="Position" />
            <Grid ColumnDefinitions="14,*,36" RowDefinitions="Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="X" />
              <Slider Grid.Row="0" Grid.Column="1" Minimum="-20" Maximum="20"
                      Value="{Binding OffsetX}" TickFrequency="0.5" />
              <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                         Text="{Binding OffsetX, StringFormat={}{0:F1}}" />
              <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Y" />
              <Slider Grid.Row="1" Grid.Column="1" Minimum="-20" Maximum="20"
                      Value="{Binding OffsetY}" TickFrequency="0.5" />
              <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"
                         Text="{Binding OffsetY, StringFormat={}{0:F1}}" />
              <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Z" />
              <Slider Grid.Row="2" Grid.Column="1" Minimum="-20" Maximum="20"
                      Value="{Binding OffsetZ}" TickFrequency="0.5" />
              <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center"
                         Text="{Binding OffsetZ, StringFormat={}{0:F1}}" />
            </Grid>

            <!-- Rotation -->
            <TextBlock FontSize="12" FontWeight="Bold" Text="Rotation (°)" />
            <Grid ColumnDefinitions="14,*,36" RowDefinitions="Auto,Auto,Auto">
              <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Y" />
              <Slider Grid.Row="0" Grid.Column="1" Minimum="-180" Maximum="180"
                      Value="{Binding OffsetYaw}" TickFrequency="5" />
              <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center"
                         Text="{Binding OffsetYaw, StringFormat={}{0:F0}}°" />
              <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="P" />
              <Slider Grid.Row="1" Grid.Column="1" Minimum="-180" Maximum="180"
                      Value="{Binding OffsetPitch}" TickFrequency="5" />
              <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"
                         Text="{Binding OffsetPitch, StringFormat={}{0:F0}}°" />
              <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="R" />
              <Slider Grid.Row="2" Grid.Column="1" Minimum="-180" Maximum="180"
                      Value="{Binding OffsetRoll}" TickFrequency="5" />
              <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center"
                         Text="{Binding OffsetRoll, StringFormat={}{0:F0}}°" />
            </Grid>

          </StackPanel>
        </Border>

        <!-- Feature Summary -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="3">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="📋 All Features Demo" />
            <TextBlock Text="✓ 3 Loop Modes: Loop / Once / PingPong" FontSize="11" />
            <TextBlock Text="✓ TimeScale (playback speed)" FontSize="11" />
            <TextBlock Text="✓ External Update (manual control)" FontSize="11" />
            <TextBlock Text="✓ Animation Reset / Switch" FontSize="11" />
            <TextBlock Text="✓ Animation Graph (State Machine)" FontSize="11" />
            <TextBlock Text="✓ Blend Space (2D IDW)" FontSize="11" />
            <TextBlock Text="✓ Crossfade Transitions" FontSize="11" />
          </StackPanel>
        </Border>

      </StackPanel>
    </ScrollViewer>

    <!-- 3D Viewport -->
    <Border Theme="{StaticResource CardBorder}" Padding="8">
      <a:Aura3DView x:Name="aura3DView"
                    SceneInitialized="Aura3DView_SceneInitialized"
                    SceneUpdated="Aura3DView_SceneUpdated">
      </a:Aura3DView>
    </Border>
  </DockPanel>
</UserControl>
