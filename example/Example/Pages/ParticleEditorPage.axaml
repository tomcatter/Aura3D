<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://github.com/CeSun/Aura3D"
             xmlns:vm="clr-namespace:Example.ViewModels"
             x:DataType="vm:ParticleEditorViewModel"
             x:Class="Example.Pages.ParticleEditorPage">

  <Design.DataContext>
    <vm:ParticleEditorViewModel />
  </Design.DataContext>

  <UserControl.Resources>
  </UserControl.Resources>

  <Grid RowDefinitions="*,300">

    <!-- Row 0: Viewport + Stats overlay -->
    <Grid Grid.Row="0">
      <a:Aura3DView x:Name="aura3DView"
                    SceneInitialized="SceneInitialized"
                    SceneUpdated="SceneUpdated"/>

      <!-- Stats overlay (top-right corner) -->
      <Border HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="8" Theme="{StaticResource CardBorder}" Padding="10" Background="#1E1E2E" Opacity="0.85">
        <StackPanel Spacing="6" Width="180">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
            <TextBlock Text="{Binding CurrentFps}" FontSize="36" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="FPS" FontSize="14" Foreground="#888" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
          </StackPanel>
          <Border Background="#333" CornerRadius="3" Height="8" HorizontalAlignment="Stretch">
            <Border Background="{Binding FpsBarColor}" CornerRadius="3"
                    Width="{Binding FpsBarWidth}" Height="8" HorizontalAlignment="Left"/>
          </Border>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
            <StackPanel Spacing="0">
              <TextBlock Text="MIN" FontSize="10" Foreground="#888" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding MinFps}" FontSize="16" FontWeight="Bold" Foreground="#FF6B6B" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Spacing="0">
              <TextBlock Text="AVG" FontSize="10" Foreground="#888" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding AvgFps}" FontSize="16" FontWeight="Bold" Foreground="#FFD93D" HorizontalAlignment="Center"/>
            </StackPanel>
            <StackPanel Spacing="0">
              <TextBlock Text="MAX" FontSize="10" Foreground="#888" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding MaxFps}" FontSize="16" FontWeight="Bold" Foreground="#6BCB77" HorizontalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
          <TextBlock Text="{Binding DetailText}" FontSize="11" Foreground="#AAA" TextWrapping="Wrap"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Row 1: Bottom panel — emitter columns laid out horizontally -->
    <Border Grid.Row="1" BorderThickness="0,1,0,0" Theme="{StaticResource CardBorder}">
      <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
        <StackPanel Orientation="Horizontal" Spacing="2">

          <!-- System Position panel (first column) -->
          <Border Width="160" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
              <StackPanel Spacing="4">
                <Border Theme="{StaticResource CardBorder}" Padding="6">
                  <TextBlock Text="System" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Border>
                <Border Theme="{StaticResource CardBorder}" Padding="6">
                  <StackPanel Spacing="3">
                    <TextBlock FontSize="12" FontWeight="Bold" Text="Position"/>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="X:" Width="14" VerticalAlignment="Center" FontSize="10"/>
                      <Slider Minimum="-20" Maximum="20" Value="{Binding PosX}" Width="80"/>
                      <TextBlock Text="{Binding PosX, StringFormat={}{0:F1}}" Width="30" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="Y:" Width="14" VerticalAlignment="Center" FontSize="10"/>
                      <Slider Minimum="-5" Maximum="20" Value="{Binding PosY}" Width="80"/>
                      <TextBlock Text="{Binding PosY, StringFormat={}{0:F1}}" Width="30" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="Z:" Width="14" VerticalAlignment="Center" FontSize="10"/>
                      <Slider Minimum="-20" Maximum="20" Value="{Binding PosZ}" Width="80"/>
                      <TextBlock Text="{Binding PosZ, StringFormat={}{0:F1}}" Width="30" FontSize="10" VerticalAlignment="Center"/>
                    </StackPanel>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>
          </Border>

          <!-- Emitter panels -->
          <ItemsControl ItemsSource="{Binding Emitters}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="2"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:EmitterViewModel">
                <Border Width="260" Padding="4" Theme="{StaticResource CardBorder}"
                        PointerPressed="EmitterBar_Click">
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4">

                      <!-- Emitter header with name + delete button -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6">
                        <DockPanel>
                          <Button DockPanel.Dock="Right" Command="{Binding DeleteCommand}"
                                  Content="x" Width="24" Height="24" FontSize="11" FontWeight="Bold"
                                  Padding="0" Margin="4,0,0,0"/>
                          <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold"
                                     VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </DockPanel>
                      </Border>

                      <!-- Render Mode -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6">
                        <StackPanel Spacing="3">
                          <TextBlock FontSize="12" FontWeight="Bold" Text="Render Mode"/>
                          <ComboBox SelectedIndex="{Binding RenderMode}" Width="120" FontSize="10" HorizontalAlignment="Left">
                            <ComboBoxItem>Billboard</ComboBoxItem>
                            <ComboBoxItem>Mesh</ComboBoxItem>
                          </ComboBox>
                        </StackPanel>
                      </Border>

                      <!-- Billboard Texture (visible when RenderMode == 0) -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6" IsVisible="{Binding IsBillboard}">
                        <StackPanel Spacing="3">
                          <TextBlock FontSize="12" FontWeight="Bold" Text="Texture"/>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBox Text="{Binding TexturePath}" Width="170" FontSize="10" IsReadOnly="True"/>
                            <Button Content="..." Click="PickTexture_Click" FontSize="10" Width="28"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Flip X:" Width="36" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding FlipbookTilesX}" Width="36" FontSize="10"/>
                            <TextBlock Text="Y:" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding FlipbookTilesY}" Width="36" FontSize="10"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <!-- Mesh (visible when RenderMode == 1) -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6" IsVisible="{Binding IsMesh}">
                        <StackPanel Spacing="3">
                          <TextBlock FontSize="12" FontWeight="Bold" Text="Mesh"/>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBox Text="{Binding MeshPath}" Width="170" FontSize="10" IsReadOnly="True"/>
                            <Button Content="..." Click="PickMesh_Click" FontSize="10" Width="28"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Scale:" Width="36" VerticalAlignment="Center" FontSize="10"/>
                            <Slider Minimum="0.01" Maximum="10" Value="{Binding MeshScale}" Width="120"/>
                            <TextBlock Text="{Binding MeshScale, StringFormat={}{0:F2}}" Width="34" FontSize="10" VerticalAlignment="Center"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <!-- Emission -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6">
                        <StackPanel Spacing="3">
                          <TextBlock FontSize="12" FontWeight="Bold" Text="Emission"/>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Rate:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <Slider Minimum="10" Maximum="5000" Value="{Binding EmissionRate}" Width="120"/>
                            <TextBlock Text="{Binding EmissionRate, StringFormat={}{0:F0}}" Width="34" FontSize="10" VerticalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Shape:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <ComboBox SelectedIndex="{Binding ShapeIndex}" Width="80" FontSize="10">
                              <ComboBoxItem>Point</ComboBoxItem>
                              <ComboBoxItem>Sphere</ComboBoxItem>
                              <ComboBoxItem>SphereSrf</ComboBoxItem>
                              <ComboBoxItem>Box</ComboBoxItem>
                              <ComboBoxItem>Cone</ComboBoxItem>
                              <ComboBoxItem>Circle</ComboBoxItem>
                              <ComboBoxItem>Hemisp</ComboBoxItem>
                            </ComboBox>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Size:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding ShapeSizeX}" Width="36" FontSize="10"/>
                            <TextBox Text="{Binding ShapeSizeY}" Width="36" FontSize="10"/>
                            <TextBox Text="{Binding ShapeSizeZ}" Width="36" FontSize="10"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Cone:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <Slider Minimum="1" Maximum="90" Value="{Binding ConeAngle}" Width="120"/>
                            <TextBlock Text="{Binding ConeAngle, StringFormat={}{0:F0}°}" Width="30" FontSize="10" VerticalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Max:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding MaxParticles}" Width="60" FontSize="10"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <!-- Lifetime & Size -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6">
                        <StackPanel Spacing="3">
                          <TextBlock FontSize="12" FontWeight="Bold" Text="Lifetime &amp; Size"/>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Life:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding LifetimeMin}" Width="36" FontSize="10"/>
                            <TextBlock Text="-" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding LifetimeMax}" Width="36" FontSize="10"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Start:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding StartSizeMin}" Width="36" FontSize="10"/>
                            <TextBlock Text="-" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding StartSizeMax}" Width="36" FontSize="10"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="End:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding EndSizeMin}" Width="36" FontSize="10"/>
                            <TextBlock Text="-" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding EndSizeMax}" Width="36" FontSize="10"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <!-- Velocity -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6">
                        <StackPanel Spacing="3">
                          <TextBlock FontSize="12" FontWeight="Bold" Text="Velocity"/>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="X:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding VelocityXMin}" Width="36" FontSize="10"/>
                            <TextBlock Text="-" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding VelocityXMax}" Width="36" FontSize="10"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Y:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding VelocityYMin}" Width="36" FontSize="10"/>
                            <TextBlock Text="-" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding VelocityYMax}" Width="36" FontSize="10"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Z:" Width="32" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding VelocityZMin}" Width="36" FontSize="10"/>
                            <TextBlock Text="-" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding VelocityZMax}" Width="36" FontSize="10"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <!-- Color (Billboard only) -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6" IsVisible="{Binding IsBillboard}">
                        <StackPanel Spacing="3">
                          <TextBlock FontSize="12" FontWeight="Bold" Text="Color"/>
                          <TextBlock Text="Start (RGBA):" FontSize="10"/>
                          <StackPanel Orientation="Horizontal" Spacing="2">
                            <TextBox Text="{Binding StartColorR}" Width="32" FontSize="10"/>
                            <TextBox Text="{Binding StartColorG}" Width="32" FontSize="10"/>
                            <TextBox Text="{Binding StartColorB}" Width="32" FontSize="10"/>
                            <TextBox Text="{Binding StartColorA}" Width="32" FontSize="10"/>
                          </StackPanel>
                          <TextBlock Text="End (RGBA):" FontSize="10"/>
                          <StackPanel Orientation="Horizontal" Spacing="2">
                            <TextBox Text="{Binding EndColorR}" Width="32" FontSize="10"/>
                            <TextBox Text="{Binding EndColorG}" Width="32" FontSize="10"/>
                            <TextBox Text="{Binding EndColorB}" Width="32" FontSize="10"/>
                            <TextBox Text="{Binding EndColorA}" Width="32" FontSize="10"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <!-- Physics -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6">
                        <StackPanel Spacing="3">
                          <TextBlock FontSize="12" FontWeight="Bold" Text="Physics"/>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Grav:" Width="30" VerticalAlignment="Center" FontSize="10"/>
                            <Slider Minimum="-20" Maximum="20" Value="{Binding GravityY}" Width="110"/>
                            <TextBlock Text="{Binding GravityY, StringFormat={}{0:F1}}" Width="34" FontSize="10" VerticalAlignment="Center"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Damp:" Width="30" VerticalAlignment="Center" FontSize="10"/>
                            <Slider Minimum="0" Maximum="2" Value="{Binding Damping}" Width="110"/>
                            <TextBlock Text="{Binding Damping, StringFormat={}{0:F2}}" Width="34" FontSize="10" VerticalAlignment="Center"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <!-- Rotation -->
                      <Border Theme="{StaticResource CardBorder}" Padding="6">
                        <StackPanel Spacing="3">
                          <TextBlock FontSize="12" FontWeight="Bold" Text="Rotation (rad)"/>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Init:" Width="30" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding RotationMin}" Width="36" FontSize="10"/>
                            <TextBlock Text="-" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding RotationMax}" Width="36" FontSize="10"/>
                          </StackPanel>
                          <StackPanel Orientation="Horizontal" Spacing="3">
                            <TextBlock Text="Vel:" Width="30" VerticalAlignment="Center" FontSize="10"/>
                            <TextBox Text="{Binding AngularVelocityMin}" Width="36" FontSize="10"/>
                            <TextBlock Text="-" FontSize="10" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding AngularVelocityMax}" Width="36" FontSize="10"/>
                          </StackPanel>
                        </StackPanel>
                      </Border>

                      <!-- Reset -->
                      <Button Command="{Binding ResetCommand}" HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Center" FontWeight="Bold" FontSize="11">Reset</Button>

                    </StackPanel>
                  </ScrollViewer>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Add emitter button (rightmost) -->
          <Border Width="60" Padding="4">
            <Button Command="{Binding AddEmitterCommand}" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" FontSize="28" FontWeight="Bold"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">+</Button>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Border>

  </Grid>
</UserControl>
