<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:a="https://github.com/CeSun/Aura3D"
             x:Class="Example.Pages.PrimitiveTypePage">
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="10" Spacing="10">
            <TextBlock Text="Rotate:" VerticalAlignment="Center"/>
            <Button Content="⟲" Click="RotateButton_Click" ToolTip.Tip="Toggle auto-rotation"/>
            <TextBlock x:Name="infoText" Text="FPS: --" VerticalAlignment="Center"/>
        </StackPanel>

        <a:Aura3DView x:Name="aura3Dview"
                       SceneInitialized="Aura3DView_SceneInitialized"
                       SceneUpdated="Aura3DView_SceneUpdated"/>
    </DockPanel>
</UserControl>
