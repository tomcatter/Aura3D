<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:a="https://github.com/CeSun/Aura3D"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Example.ViewModels"
             xmlns:core="clr-namespace:Aura3D.Core.Renderers;assembly=Aura3D.Core"
             x:DataType="vm:DebugTestViewModel"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
             xmlns:acr="clr-namespace:Aura3D.Pipeline.PBR;assembly=Aura3D.Pipeline.PBR"
             x:Class="Example.Pages.DebugTestPage">

  <Design.DataContext>
    <vm:DebugTestViewModel />
  </Design.DataContext>

  <DockPanel>
    <!-- ═══════════════════════════════════════════════ Right Control Panel ═══ -->
    <ScrollViewer DockPanel.Dock="Right" Width="320">
      <StackPanel Spacing="8" Margin="8">

        <!-- Debug Draw -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="4">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="🔧 Debug Draw" />
            <CheckBox IsChecked="{Binding DebugEnable}">
              <TextBlock Text="Enable All Debug Draw" FontWeight="Bold" />
            </CheckBox>
            <Separator Height="1" Background="#444" Margin="0,2" />
            <CheckBox IsChecked="{Binding ShowAxes}" Content="Axes" />
            <CheckBox IsChecked="{Binding ShowGrid}" Content="Grid" />
            <CheckBox IsChecked="{Binding ShowBoundingBox}" Content="Bounding Box" />
            <CheckBox IsChecked="{Binding ShowDirectionalLight}" Content="Directional Light" />
            <CheckBox IsChecked="{Binding ShowPointLight}" Content="Point Light" />
            <CheckBox IsChecked="{Binding ShowSpotLight}" Content="Spot Light" />
            <CheckBox IsChecked="{Binding ShowCamera}" Content="Camera" />
            <CheckBox IsChecked="{Binding ShowBone}" Content="Bones" />
            <CheckBox IsChecked="{Binding ShowParticleBounds}" Content="Particle Bounds" />
          </StackPanel>
        </Border>

        <!-- Picking -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="4">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="🎯 Picking" />
            <CheckBox IsChecked="{Binding EnablePicking}" Content="Enable Picking" />
            <TextBlock Text="{Binding PickInfo}" FontSize="11"
                       Foreground="#0F0" TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <!-- Lights -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="6">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="💡 Lights" />

            <!-- Directional Light -->
            <Border Theme="{StaticResource CardBorder}" CornerRadius="4" Padding="6">
              <StackPanel Spacing="4">
                <CheckBox IsChecked="{Binding DirLightEnabled}" Content="☀ Directional" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Rot X:" FontSize="11" Width="45" VerticalAlignment="Center" />
                  <Slider Minimum="-180" Maximum="180" Value="{Binding DirLightRotX}" Width="110" />
                  <TextBlock Text="{Binding DirLightRotX, StringFormat={}{0:F0}°}" FontSize="11"
                             Width="35" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Rot Y:" FontSize="11" Width="45" VerticalAlignment="Center" />
                  <Slider Minimum="-180" Maximum="180" Value="{Binding DirLightRotY}" Width="110" />
                  <TextBlock Text="{Binding DirLightRotY, StringFormat={}{0:F0}°}" FontSize="11"
                             Width="35" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Irradiance:" FontSize="11" Width="45" VerticalAlignment="Center" />
                  <Slider Minimum="0" Maximum="200000" Value="{Binding DirLightIrradiance}" Width="110" />
                  <TextBlock Text="{Binding DirLightIrradiance, StringFormat={}{0:F0}}" FontSize="11"
                             Width="40" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Color:" FontSize="11" Width="45" VerticalAlignment="Center" />
                  <ColorPicker Color="{Binding DirLightColor}"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Point Light -->
            <Border Theme="{StaticResource CardBorder}" CornerRadius="4" Padding="6">
              <StackPanel Spacing="4">
                <CheckBox IsChecked="{Binding PointLightEnabled}" Content="💡 Point" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="X:" FontSize="11" Width="20" VerticalAlignment="Center" />
                  <Slider Minimum="-30" Maximum="30" Value="{Binding PointLightX}" Width="100" />
                  <TextBlock Text="{Binding PointLightX, StringFormat={}{0:F0}}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Y:" FontSize="11" Width="20" VerticalAlignment="Center" />
                  <Slider Minimum="0" Maximum="30" Value="{Binding PointLightY}" Width="100" />
                  <TextBlock Text="{Binding PointLightY, StringFormat={}{0:F0}}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Z:" FontSize="11" Width="20" VerticalAlignment="Center" />
                  <Slider Minimum="-30" Maximum="30" Value="{Binding PointLightZ}" Width="100" />
                  <TextBlock Text="{Binding PointLightZ, StringFormat={}{0:F0}}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Intensity:" FontSize="11" Width="35" VerticalAlignment="Center" />
                  <Slider Minimum="0" Maximum="50000" Value="{Binding PointLightIntensity}" Width="120" />
                  <TextBlock Text="{Binding PointLightIntensity, StringFormat={}{0:F0}}" FontSize="11"
                             Width="40" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Color:" FontSize="11" Width="45" VerticalAlignment="Center" />
                  <ColorPicker Color="{Binding PointLightColor}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Radius:" FontSize="11" Width="60" VerticalAlignment="Center" />
                  <Slider Minimum="1" Maximum="50" Value="{Binding PointLightRadius}" Width="130" />
                  <TextBlock Text="{Binding PointLightRadius, StringFormat={}{0:F0}}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Spot Light -->
            <Border Theme="{StaticResource CardBorder}" CornerRadius="4" Padding="6">
              <StackPanel Spacing="4">
                <CheckBox IsChecked="{Binding SpotLightEnabled}" Content="🔦 Spot" FontWeight="Bold" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="X:" FontSize="11" Width="20" VerticalAlignment="Center" />
                  <Slider Minimum="-30" Maximum="30" Value="{Binding SpotLightX}" Width="100" />
                  <TextBlock Text="{Binding SpotLightX, StringFormat={}{0:F0}}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Y:" FontSize="11" Width="20" VerticalAlignment="Center" />
                  <Slider Minimum="0" Maximum="30" Value="{Binding SpotLightY}" Width="100" />
                  <TextBlock Text="{Binding SpotLightY, StringFormat={}{0:F0}}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Z:" FontSize="11" Width="20" VerticalAlignment="Center" />
                  <Slider Minimum="-30" Maximum="30" Value="{Binding SpotLightZ}" Width="100" />
                  <TextBlock Text="{Binding SpotLightZ, StringFormat={}{0:F0}}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
                <Separator Height="1" Background="#444" Margin="0,2" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Rot X:" FontSize="11" Width="45" VerticalAlignment="Center" />
                  <Slider Minimum="-180" Maximum="180" Value="{Binding SpotLightRotX}" Width="110" />
                  <TextBlock Text="{Binding SpotLightRotX, StringFormat={}{0:F0}°}" FontSize="11"
                             Width="35" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Rot Y:" FontSize="11" Width="45" VerticalAlignment="Center" />
                  <Slider Minimum="-180" Maximum="180" Value="{Binding SpotLightRotY}" Width="110" />
                  <TextBlock Text="{Binding SpotLightRotY, StringFormat={}{0:F0}°}" FontSize="11"
                             Width="35" VerticalAlignment="Center" />
                </StackPanel>
                <Separator Height="1" Background="#444" Margin="0,2" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Intensity:" FontSize="11" Width="35" VerticalAlignment="Center" />
                  <Slider Minimum="0" Maximum="50000" Value="{Binding SpotLightIntensity}" Width="120" />
                  <TextBlock Text="{Binding SpotLightIntensity, StringFormat={}{0:F0}}" FontSize="11"
                             Width="40" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Color:" FontSize="11" Width="45" VerticalAlignment="Center" />
                  <ColorPicker Color="{Binding SpotLightColor}"/>
                </StackPanel>
                <Separator Height="1" Background="#444" Margin="0,2" />
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Inner Cone:" FontSize="11" Width="60" VerticalAlignment="Center" />
                  <Slider Minimum="1" Maximum="60" Value="{Binding SpotLightInnerAngle}" Width="130" />
                  <TextBlock Text="{Binding SpotLightInnerAngle, StringFormat={}{0:F0}°}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Outer Cone:" FontSize="11" Width="60" VerticalAlignment="Center" />
                  <Slider Minimum="1" Maximum="80" Value="{Binding SpotLightOuterAngle}" Width="130" />
                  <TextBlock Text="{Binding SpotLightOuterAngle, StringFormat={}{0:F0}°}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="4">
                  <TextBlock Text="Radius:" FontSize="11" Width="60" VerticalAlignment="Center" />
                  <Slider Minimum="1" Maximum="50" Value="{Binding SpotLightRadius}" Width="130" />
                  <TextBlock Text="{Binding SpotLightRadius, StringFormat={}{0:F0}}" FontSize="11"
                             Width="30" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <!-- Culling & Scene Config -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="6">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="📊 Culling &amp; Scene" />
            <CheckBox IsChecked="{Binding EnableFrustumCulling}"
                      Content="Frustum Culling" />

            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock VerticalAlignment="Center" Text="Static:" Width="60" FontSize="11" />
              <TextBox Text="{Binding StaticMeshCount}" Width="50" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock VerticalAlignment="Center" Text="Skinned:" Width="60" FontSize="11" />
              <TextBox Text="{Binding SkinnedMeshCount}" Width="50" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock VerticalAlignment="Center" Text="BB Padding:" Width="60" FontSize="11" />
              <TextBox Text="{Binding BoundingBoxPadding}" Width="50" />
            </StackPanel>
            <Button FontWeight="Bold" Command="{Binding BuildCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">🔨 Build</Button>
          </StackPanel>
        </Border>

        <!-- Visibility Stats -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="4">
            <TextBlock FontSize="14" FontWeight="Bold"
                       Foreground="{DynamicResource SemiGrey10}" Text="👁 Visibility" />
            <TextBlock Text="{Binding DetailText}" FontSize="11"
                       Foreground="#AAA" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="Visible:" Width="36" />
              <TextBlock Text="{Binding VisibleCount}" FontWeight="Bold" Foreground="#6BCB77" />
              <TextBlock Text=" / " />
              <TextBlock Text="{Binding TotalCount}" FontWeight="Bold" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Fire Position -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="4">
            <TextBlock FontSize="14" FontWeight="Bold" Text="Fire Position" />
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="X:" Width="20" VerticalAlignment="Center" FontSize="11"/>
              <Slider Minimum="-20" Maximum="20" Value="{Binding FirePosX}" Width="130"/>
              <TextBlock Text="{Binding FirePosX, StringFormat={}{0:F1}}" Width="40" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="Y:" Width="20" VerticalAlignment="Center" FontSize="11"/>
              <Slider Minimum="0" Maximum="10" Value="{Binding FirePosY}" Width="130"/>
              <TextBlock Text="{Binding FirePosY, StringFormat={}{0:F1}}" Width="40" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="Z:" Width="20" VerticalAlignment="Center" FontSize="11"/>
              <Slider Minimum="-20" Maximum="20" Value="{Binding FirePosZ}" Width="130"/>
              <TextBlock Text="{Binding FirePosZ, StringFormat={}{0:F1}}" Width="40" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Dust Position (Mesh Particles) -->
        <Border Theme="{StaticResource CardBorder}" Padding="10">
          <StackPanel Spacing="4">
            <TextBlock FontSize="14" FontWeight="Bold" Text="🪨 Dust (Mesh Particles)" />
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="X:" Width="20" VerticalAlignment="Center" FontSize="11"/>
              <Slider Minimum="-20" Maximum="20" Value="{Binding DustPosX}" Width="130"/>
              <TextBlock Text="{Binding DustPosX, StringFormat={}{0:F1}}" Width="40" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="Y:" Width="20" VerticalAlignment="Center" FontSize="11"/>
              <Slider Minimum="0" Maximum="10" Value="{Binding DustPosY}" Width="130"/>
              <TextBlock Text="{Binding DustPosY, StringFormat={}{0:F1}}" Width="40" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="Z:" Width="20" VerticalAlignment="Center" FontSize="11"/>
              <Slider Minimum="-20" Maximum="20" Value="{Binding DustPosZ}" Width="130"/>
              <TextBlock Text="{Binding DustPosZ, StringFormat={}{0:F1}}" Width="40" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            <Separator Height="1" Background="#444" Margin="0,2" />
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="RX:" Width="25" VerticalAlignment="Center" FontSize="11"/>
              <Slider Minimum="-180" Maximum="180" Value="{Binding DustRotX}" Width="125"/>
              <TextBlock Text="{Binding DustRotX, StringFormat={}{0:F0}°}" Width="35" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="RY:" Width="25" VerticalAlignment="Center" FontSize="11"/>
              <Slider Minimum="-180" Maximum="180" Value="{Binding DustRotY}" Width="125"/>
              <TextBlock Text="{Binding DustRotY, StringFormat={}{0:F0}°}" Width="35" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock Text="RZ:" Width="25" VerticalAlignment="Center" FontSize="11"/>
              <Slider Minimum="-180" Maximum="180" Value="{Binding DustRotZ}" Width="125"/>
              <TextBlock Text="{Binding DustRotZ, StringFormat={}{0:F0}°}" Width="35" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- FPS -->
        <Border Theme="{StaticResource CardBorder}" Padding="10"
                Background="#1E1E2E">
          <StackPanel Spacing="6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
              <TextBlock Text="{Binding CurrentFps}" FontSize="36" FontWeight="Bold"
                         Foreground="White" />
              <TextBlock Text="FPS" FontSize="14" Foreground="#888"
                         VerticalAlignment="Bottom" Margin="0,0,0,6" />
            </StackPanel>

            <Border Background="#333" CornerRadius="3" Height="8" HorizontalAlignment="Stretch">
              <Border Background="{Binding FpsBarColor}" CornerRadius="3"
                      Width="{Binding FpsBarWidth}" Height="8"
                      HorizontalAlignment="Left" />
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
              <StackPanel Spacing="0">
                <TextBlock Text="MIN" FontSize="10" Foreground="#888"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding MinFps}" FontSize="16" FontWeight="Bold"
                           Foreground="#FF6B6B" HorizontalAlignment="Center" />
              </StackPanel>
              <StackPanel Spacing="0">
                <TextBlock Text="AVG" FontSize="10" Foreground="#888"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding AvgFps}" FontSize="16" FontWeight="Bold"
                           Foreground="#FFD93D" HorizontalAlignment="Center" />
              </StackPanel>
              <StackPanel Spacing="0">
                <TextBlock Text="MAX" FontSize="10" Foreground="#888"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding MaxFps}" FontSize="16" FontWeight="Bold"
                           Foreground="#6BCB77" HorizontalAlignment="Center" />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <TextBlock Text="🎮 Right-click drag to rotate | Scroll to zoom | WASD to move"
                   FontSize="10" FontStyle="Italic"
                   Foreground="{DynamicResource SemiGrey10}" Margin="4,0" />

      </StackPanel>
    </ScrollViewer>

    <!-- ═══════════════════════════════════════════════ 3D Viewport ═══ -->
    <a:Aura3DView x:Name="aura3DView"
                  SceneInitialized="Aura3DView_SceneInitialized"
                  SceneUpdated="Aura3DView_SceneUpdated"  >
      <a:Aura3DView.PipelineSettings>
        <core:PipelineSettings CsmCascadeCount="4"
                               CsmShadowMapResolution="2048"
                               CsmSplitLambda="0.75" />
      </a:Aura3DView.PipelineSettings>
    </a:Aura3DView>
  </DockPanel>
</UserControl>
