<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:a="https://github.com/CeSun/Aura3D"
             xmlns:vm="using:Example.ViewModels"
             x:DataType="vm:PickingTestViewModel"
             x:Class="Example.Pages.PickingTestPage">
    <DockPanel>
        <!-- 顶部工具栏 -->
        <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="10,8"
                BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="15">
                <TextBlock Text="拾取测试" FontSize="18" FontWeight="Bold"
                           VerticalAlignment="Center" Foreground="#FFF"/>
                <Separator Width="1" Height="24" Background="#555" Margin="5,0"/>
                <CheckBox IsChecked="{Binding EnablePicking}"
                          Content="启用拾取" Foreground="#CCC" VerticalAlignment="Center"/>
                <CheckBox IsChecked="{Binding ShowBoundingBox}"
                          Content="包围盒" Foreground="#CCC" VerticalAlignment="Center"/>
                <Separator Width="1" Height="24" Background="#555" Margin="5,0"/>
                <TextBlock Text="{Binding PickInfo}" FontSize="13"
                           VerticalAlignment="Center" Foreground="#0F0"
                           TextWrapping="Wrap" MaxWidth="550"/>
                <Separator Width="1" Height="24" Background="#555" Margin="5,0"/>
                <TextBlock Text="{Binding ModelCount}" FontSize="12"
                           VerticalAlignment="Center" Foreground="#AAA"/>
            </StackPanel>
        </Border>

        <!-- 3D 视图 -->
        <a:Aura3DView x:Name="aura3Dview"
                      SceneInitialized="Aura3DView_SceneInitialized"
                      SceneUpdated="Aura3DView_SceneUpdated" />
    </DockPanel>
</UserControl>
