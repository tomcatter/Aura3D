<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:a="https://github.com/CeSun/Aura3D"
             xmlns:pbr="clr-namespace:Aura3D.Pipeline.PBR;assembly=Aura3D.Pipeline.PBR"
             xmlns:core="clr-namespace:Aura3D.Core.Renderers;assembly=Aura3D.Core"
             x:Class="Example.Pages.CascadedShadowMapsPage">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <!-- 渲染区域：启用 CSM（3 级联） -->
        <a:Aura3DView Grid.Column="0"
                      x:Name="aura3Dview"
                      x:TypeArguments="pbr:PBRDeferredPipeline"
                      SceneInitialized="Aura3DView_SceneInitialized"
                      SceneUpdated="Aura3DView_SceneUpdated">
            <a:Aura3DView.PipelineSettings>
                <core:PipelineSettings CsmCascadeCount="3"
                                       CsmSplitLambda="0.5"
                                       DirectionalLightLimit="4"
                                       DepthFormat="DepthComponent32f" />
            </a:Aura3DView.PipelineSettings>
        </a:Aura3DView>

        <!-- 控制面板 -->
        <StackPanel Grid.Column="1" Margin="10" Spacing="8">
            <TextBlock FontWeight="Bold" FontSize="14" Text="CSM Settings" />

            <TextBlock Text="Cascade Count:" />
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="1" Width="30" Click="CascadeCount_Click" />
                <Button Content="2" Width="30" Click="CascadeCount_Click" />
                <Button Content="3" Width="30" Click="CascadeCount_Click" />
                <Button Content="4" Width="30" Click="CascadeCount_Click" />
            </StackPanel>

            <TextBlock Text="Split Lambda:" />
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Content="0.2" Click="SplitLambda_Click" />
                <Button Content="0.5" Click="SplitLambda_Click" />
                <Button Content="0.8" Click="SplitLambda_Click" />
            </StackPanel>

            <Separator />

            <TextBlock Text="Debug Visuals:" />
            <TextBlock x:Name="txtInfo" FontSize="11" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</UserControl>
